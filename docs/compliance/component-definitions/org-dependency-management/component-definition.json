{
  "component-definition": {
    "uuid": "9ce247c8-f6cf-4918-9a14-523696d90365",
    "metadata": {
      "title": "org-dependency-management Component Definition",
      "last-modified": "2025-07-17T00:00:00.000000+00:00",
